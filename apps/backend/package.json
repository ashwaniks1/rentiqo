{
  "name": "@rentiqo/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/__tests__/**/*.test.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@rentiqo/contracts": "file:../../packages/contracts",
    "bcryptjs": "^3.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
